# Backend configuration — copy to `.env` and fill in real values.
# The real `.env` is git-ignored; never commit secrets.

# Port the API listens on. Standardized to 5001 (the mobile app expects this).
PORT=5001

# MongoDB connection string.
MONGO_URI=mongodb://127.0.0.1:27017/ipay_simulation

# Secret used to sign/verify JWTs. Use a long random string in any real setup.
JWT_SECRET=change-me-to-a-long-random-string

# Twilio (optional) — OTP SMS delivery. Leave blank to skip real SMS (OTP is
# still logged to the server console in development).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMTP (optional) — OTP email delivery via nodemailer (Gmail service).
SMTP_EMAIL=
SMTP_PASSWORD=
